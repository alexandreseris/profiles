{
    "------------ FONT ------------": "#####################################################################################",
    "-- font dl": "https://monaspace.githubnext.com",
    "editor.fontFamily": "'Monaspace Neon Var', Consolas, 'Courier New', monospace",
    "errorLens.fontFamily": "'Monaspace Neon Var'",
    "editor.codeLensFontFamily": "'Monaspace Neon Var'",
    "scm.inputFontFamily": "'Monaspace Neon Var'",
    "chat.editor.fontFamily": "'Monaspace Neon Var'",
    "debug.console.fontFamily": "'Monaspace Neon Var'",
    "markdown.preview.fontFamily": "'Monaspace Neon Var'",
    "editor.inlayHints.fontFamily": "'Monaspace Neon Var'",
    "terminal.integrated.fontFamily": "'Monaspace Neon Var'",
    "------------ UI ------------": "#####################################################################################",
    "workbench.colorTheme": "Solarized Light",
    "window.title": "${dirty} ${rootNameShort} -▸ ${activeEditorMedium}",
    "window.commandCenter": false,
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "search.collapseResults": "alwaysCollapse",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.copyRelativePathSeparator": "/",
    "workbench.editor.languageDetection": false,
    "workbench.editor.wrapTabs": true,
    "workbench.startupEditor": "none",
    "workbench.sideBar.location": "right",
    "workbench.tree.indent": 14,
    "workbench.colorCustomizations": {
        "-- peacock_colors --": "",
        "activityBar.activeBackground": "#f7f7f7",
        "activityBar.background": "#f7f7f7",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#df9f9f",
        "activityBarBadge.foreground": "#15202b",
        "commandCenter.border": "#15202b99",
        "sash.hoverBorder": "#f7f7f7",
        "statusBar.background": "#dedede",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#c4c4c4",
        "statusBarItem.remoteBackground": "#dedede",
        "statusBarItem.remoteForeground": "#15202b",
        "titleBar.activeBackground": "#dedede",
        "titleBar.activeForeground": "#15202b",
        "titleBar.inactiveBackground": "#dedede99",
        "titleBar.inactiveForeground": "#15202b99",
        "editorWhitespace.foreground": "#7c7b34",
        "editorOverviewRuler.errorForeground": "#ca0000",
        "editorOverviewRuler.warningForeground": "#cc6d00",
        "editorOverviewRuler.infoForeground": "#d9dd00",
        "editor.lineHighlightBackground": "#ffffff",
        "editor.lineHighlightBorder": "#9e9edb",
        "editor.selectionBackground": "#00000054",
        "editor.selectionHighlightBackground": "#00000054",
        "editor.findMatchHighlightBackground": "#ff880086",
        "editorInlayHint.background": "#f0ceff59",
        "editorInlayHint.foreground": "#2020209a",
        "editorInlayHint.parameterBackground": "#f0ceff59",
        "editorInlayHint.parameterForeground": "#2020209a",
        "editorInlayHint.typeBackground": "#f0ceff59",
        "editorInlayHint.typeForeground": "#2020209a",
        "editorStickyScroll.background": "#d7f2f5",
        "editorBracketHighlight.unexpectedBracket.foreground": "#9c0000",
        "editorBracketHighlight.foreground1": "#2e00ad",
        "editorBracketHighlight.foreground2": "#a300a3",
        "editorBracketHighlight.foreground3": "#9e9b00",
        "editorBracketHighlight.foreground4": "#009da8",
        "editorBracketHighlight.foreground5": "#966100",
        "editorBracketHighlight.foreground6": "#2d9e00"
    },
    "------------ EDITEUR ------------": "#####################################################################################",
    "editor.tabSize": 4,
    "editor.indentSize": 4,
    "editor.bracketPairColorization.enabled": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": false,
    "editor.renderWhitespace": "selection",
    "editor.renderControlCharacters": true,
    "editor.renderLineHighlight": "all",
    "editor.minimap.showSlider": "always",
    "editor.minimap.size": "fill",
    "editor.minimap.renderCharacters": false,
    "editor.snippetSuggestions": "bottom",
    "editor.wordWrap": "on",
    "editor.showFoldingControls": "always",
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.maxLineCount": 10,
    "editor.stickyScroll.defaultModel": "foldingProviderModel",
    "files.eol": "\n",
    "files.encoding": "utf8",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.largeFileOptimizations": false,
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "off"
    },
    "------------ SEARCH STUFF ------------": "#####################################################################################",
    "files.exclude": {
        "venv": true,
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        ".pytest_cache": true,
        "**/__pycache__": true,
        "**/*.egg-info": true,
        ".ruff_cache": true,
        "**/.pytest_cache": true,
    },
    "search.exclude": {
        "venv": true,
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        ".pytest_cache": true,
        "**/__pycache__": true,
        "**/*.egg-info": true,
        ".ruff_cache": true,
        "**/.pytest_cache": true,
    },
    "search.defaultViewMode": "tree",
    "search.showLineNumbers": true,
    "------------ TERMINAL ------------": "#####################################################################################",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.tabs.enableAnimation": true,
    "terminal.integrated.tabs.showActiveTerminal": "always",
    "terminal.integrated.scrollback": 5000,
    "terminal.integrated.env.windows": {
        "VSCODE_WS": "${workspaceFolder}"
    },
    "terminal.integrated.defaultProfile.linux": "zsh",
    "------------ DEBUG ------------": "#####################################################################################",
    "debug.openDebug": "openOnDebugBreak",
    "debug.inlineValues": "off",
    "debug.allowBreakpointsEverywhere": true,
    "debug.console.closeOnEnd": true,
    "------------ RUST ------------": "#####################################################################################",
    "[rust]": {
        "editor.formatOnSave": true,
    },
    "------------ PYTHON ------------": "#####################################################################################",
    "python.analysis.reportExtraTelemetry": false,
    "python.analysis.languageServerMode": "full",
    "python.analysis.enableEditableInstalls": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.inlayHints.pytestParameters": true,
    "python.analysis.autoFormatStrings": true,
    "autoDocstring.docstringFormat": "google",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
        "editor.formatOnType": false,
        "diffEditor.ignoreTrimWhitespace": false,
    },
    "ruff.nativeServer": "off",
    "ruff.lint.args": [
        "--exclude",
        "venv/*",
        "--respect-gitignore",
        "--line-length",
        "120"
    ],
    "ruff.organizeImports": true,
    "ruff.lint.run": "onSave",
    "python.analysis.typeCheckingMode": "basic",
    "mypy.dmypyExecutable": "/home/aseris/venv/bin/dmypy",
    "mypy.runUsingActiveInterpreter": true,
    "debugpy.debugJustMyCode": false,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "------------ GO ------------": "#####################################################################################",
    "go.inlayHints.parameterNames": true,
    "go.inlayHints.rangeVariableTypes": true,
    "go.inlayHints.assignVariableTypes": true,
    "go.inlayHints.compositeLiteralFields": true,
    "go.inlayHints.compositeLiteralTypes": true,
    "go.inlayHints.constantValues": true,
    "go.inlayHints.functionTypeParameters": true,
    "------------ JS ------------": "#####################################################################################",
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "[javascript]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
    },
    "[typescript]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
    },
    "[vue]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
    },
    "[jsx-tags]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
    },
    "js/ts.preferences.importModuleSpecifier": "non-relative",
    "playwright.showTrace": true,
    "js/ts.inlayHints.parameterNames.enabled": "all",
    "js/ts.inlayHints.variableTypes.enabled": true,
    "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
    "js/ts.inlayHints.parameterTypes.enabled": true,
    "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
    "js/ts.inlayHints.enumMemberValues.enabled": true,
    "js/ts.locale": "en",
    "vue.inlayHints.missingProps": true,
    "vue.hover.rich": true,
    "------------ HTML/CSS ------------": "#####################################################################################",
    "[html]": {
        "editor.formatOnSave": false,
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "html.autoClosingTags": false,
    "------------ PHP ------------": "#####################################################################################",
    "php-cs-fixer.rules": "@PhpCsFixer",
    "php-cs-fixer.executablePathWindows": "php-cs-fixer.bat",
    "php-cs-fixer.executablePath": "${extensionPath}/php-cs-fixer.phar",
    "[php]": {
        "editor.quickSuggestions": {
            "comments": true
        },
        "editor.defaultFormatter": "junstyle.php-cs-fixer",
        "editor.formatOnSave": false
    },
    "php.suggest.basic": false,
    "intelephense.files.exclude": [
        "**/.git/**",
        "**/.svn/**",
        "**/.hg/**",
        "**/CVS/**",
        "**/.DS_Store/**",
        "**/node_modules/**",
        "**/bower_components/**",
        "**/vendor/**/{Test,test,Tests,tests}/**/*Test.php"
    ],
    "------------ POWERSHELL ------------": "#####################################################################################",
    "[powershell]": {
        "editor.detectIndentation": false
    },
    "------------ JSON ------------": "#####################################################################################",
    "[json]": {
        "editor.quickSuggestions": {
            "strings": true
        },
        "editor.suggest.insertMode": "replace",
        "gitlens.codeLens.scopes": [
            "document"
        ],
        "editor.detectIndentation": false,
        "editor.indentSize": 2,
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "------------ GIT ------------": "#####################################################################################",
    "diffEditor.diffAlgorithm": "advanced",
    "git.allowForcePush": true,
    "git.autofetch": true,
    "git.autofetchPeriod": 180,
    "-- 3 way editeur, if needed": "git.mergeEditor: true",
    "git.mergeEditor": false,
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "never",
    "git.allowNoVerifyCommit": true,
    "git.confirmNoVerifyCommit": false,
    "git.suggestSmartCommit": false,
    "-------------- GITLENS ------------": "#####################################################################################",
    "gitlens.advanced.messages": {
        "suppressCreatePullRequestPrompt": true
    },
    "gitlens.graph.dateStyle": "absolute",
    "gitlens.graph.dateFormat": "YYYY-MM-DD HH:mm:ss",
    "gitlens.codeLens.enabled": false,
    "gitlens.blame.heatmap.enabled": false,
    "gitlens.blame.highlight.locations": [
        "gutter",
        "line",
        "overview"
    ],
    "gitlens.changes.locations": [
        "gutter",
        "line",
        "overview"
    ],
    "gitlens.heatmap.locations": [
        "gutter",
        "line",
        "overview"
    ],
    "gitlens.views.scm.grouped.views": {
        "commits": false,
        "branches": false,
        "remotes": false,
        "stashes": false,
        "tags": false,
        "worktrees": false,
        "contributors": false,
        "repositories": false,
        "searchAndCompare": true,
        "launchpad": false
    },
    "gitlens.advanced.fileHistoryShowMergeCommits": true,
    "gitlens.views.branches.branches.layout": "list",
    "gitlens.rebaseEditor.ordering": "asc",
    "gitlens.views.stashes.files.layout": "tree",
    "------------ GITLAB/HUB ------------": "#####################################################################################",
    "gitlab.duoChat.enabled": false,
    "gitlab.duo.enabledWithoutGitlabProject": false,
    "gitlab.duoCodeSuggestions.enabled": false,
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "gitlab.customQueries": [
        {
            "name": "Issues assigned to me",
            "type": "issues",
            "scope": "assigned_to_me",
            "state": "opened",
            "noItemText": "No issues assigned to you."
        },
        {
            "name": "Issues created by me",
            "type": "issues",
            "scope": "created_by_me",
            "state": "opened",
            "noItemText": "No issues created by you."
        },
        {
            "name": "MR review",
            "type": "merge_requests",
            "reviewer": "<current_user>",
            "state": "opened",
            "noItemText": "No merge requests for you to review."
        },
        {
            "name": "MR created by me",
            "type": "merge_requests",
            "scope": "created_by_me",
            "state": "opened",
            "noItemText": "No merge requests created by you."
        },
        {
            "name": "MR all",
            "type": "merge_requests",
            "scope": "all",
            "state": "opened",
            "noItemText": "The project has no merge requests"
        }
    ],
    "------------ ESTETICS DIV ------------": "#####################################################################################",
    "peacock.color": "#dedede",
    "errorLens.enabled": true,
    "errorLens.messageTemplate": "($count) $source::$message",
    "errorLens.messageBackgroundMode": "message",
    "errorLens.statusBarIconsEnabled": true,
    "errorLens.excludeBySource": [
        "Pylance"
    ],
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 5,
    "indentRainbow.colors": [
        "rgba(255, 255, 143, 0.2)",
        "rgba(168, 255, 143, 0.2)",
        "rgba(143, 255, 208, 0.2)",
        "rgba(143, 206, 255, 0.2)",
        "rgba(215, 143, 255, 0.2)",
        "rgba(255, 143, 218, 0.2)"
    ],
    "indentRainbow.errorColor": "rgba(255, 46, 0, 0)", // nice if not too much err
    "indentRainbow.tabmixColor": "rgba(255, 138, 0, 0)", // same as above
    "indentRainbow.excludedLanguages": [
        "plaintext",
        "json"
    ],
    "------------ TELEMTRY ------------": "#####################################################################################",
    "telemetry.telemetryLevel": "off",
    "redhat.telemetry.enabled": false,
    "gitlens.telemetry.enabled": false,
    "telemetry.feedback.enabled": false,
    "partialDiff.enableTelemetry": false,
    "python.analysis.enablePerfTelemetry": false,
    "editor.experimental.treeSitterTelemetry": false,
    "------------ DIV ------------": "#####################################################################################",
    "security.workspace.trust.untrustedFiles": "open",
    "shellcheck.exclude": [
        "SC1091"
    ],
    "cSpell.userWords": [],
    "cSpell.enabledNotifications": {
        "Maximum Word Length Exceeded": false
    },
    "symlink-follow.autoFollow": true,
    "explorer.confirmPasteNative": false,

    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "terminal.integrated.initialHint": false,
    "------------ STOOPID ------------": "#####################################################################################",
    "powermode.enabled": true,
    "powermode.explosions.enabled": true,
    "powermode.shake.enabled": false,
    "powermode.combo.counterEnabled": "hide",
    "powermode.combo.timerEnabled": "hide",
    "powermode.combo.threshold": 3,
    "powermode.combo.timeout": 4,
    "powermode.combo.location": "editor",
    "powermode.presets": "flames",

    "faah.enabled": true,
    "faah.monitorTerminal": true,
    "faah.monitorDiagnostics": true,
    "faah.diagnosticsSeverity": "error",
    "faah.cooldownMs": 1500,
    "faah.terminalCooldownMs": 1500,
    "faah.diagnosticsCooldownMs": 1500,
    "faah.patternMode": "override",
    "faah.volumePercent": 70,
    "faah.showVisualNotifications": true,
    "faah.customSoundPath": "",
    "faah.quietHoursEnabled": false,
    "faah.quietHoursStart": "22:00",
    "faah.quietHoursEnd": "07:00",
    "faah.patterns": [
        "\\berror\\b",
        "\\bfailed\\b",
        "\\bfailure\\b",
        "\\bfatal\\b",
        "\\bexception\\b",
        "\\bcritical\\b",
        "\\berr(or)?[:!\\]]",
        "\\buncaught\\b",
        "UnhandledPromiseRejection",
        "Traceback \\(most recent call last\\):",
        "\\bsyntaxerror\\b",
        "\\btypeerror\\b",
        "\\breferenceerror\\b",
        "\\brangeerror\\b",
        "\\bmodule\\s+not\\s+found\\b",
        "\\bcannot\\s+find\\s+module\\b",
        "\\bno\\s+module\\s+named\\b",
        "\\bsegmentation\\s+fault\\b",
        "\\bcore\\s+dumped\\b",
        "\\bpanic:|\\bpanicked\\s+at\\b",
        "^\\s*caused\\s+by:",
        "\\bpermission\\s+denied\\b",
        "\\baccess\\s+denied\\b",
        "\\bcommand\\s+not\\s+found\\b",
        "\\btimeout(?:\\s+exceeded)?\\b",
        "\\bconnection\\s+(?:refused|reset|timed\\s*out)\\b",
        "\\bhttp\\s+5\\d\\d\\b"
    ],
    "faah.excludePatterns": [
        "^\\[[^\\]]+\\s[0-9a-f]{7,40}\\]\\s(?:feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(?:\\([^)]+\\))?!?:\\s.+$",
        "^(?:feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(?:\\([^)]+\\))?!?:\\s.+$"
    ]
}